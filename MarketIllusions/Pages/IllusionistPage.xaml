<Page x:Class="MarketIllusions.Pages.IllusionistPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="IllusionistPage"
      Background="{StaticResource WhiteBrush}">
    <Grid Margin="10">
        <TabControl>
            <!-- Создание иллюзий -->
            <TabItem Header="Создать иллюзию">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Width="400">
                        <TextBlock Text="Создание новой иллюзии" 
                                   Style="{StaticResource HeaderStyle}"/>

                        <Label Content="Название иллюзии"/>
                        <TextBox x:Name="IllusionNameTextBox" Height="35"/>

                        <Label Content="Описание"/>
                        <TextBox x:Name="IllusionDescriptionTextBox" 
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>

                        <Label Content="Сила иллюзии (0-100)"/>
                        <TextBox x:Name="IllusionPowerTextBox" 
                                 Text="50" 
                                 Height="35"/>

                        <Label Content="Целевой пользователь"/>
                        <ComboBox x:Name="TargetUserComboBox" Height="35"/>

                        <Label Content="Связанный заказ"/>
                        <ComboBox x:Name="OrderComboBox" Height="35"/>

                        <Button Content="Создать иллюзию" 
                                Height="40"
                                Margin="0,20,0,0"
                                Click="CreateIllusionButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Список иллюзий -->
            <TabItem Header="Мои иллюзии">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" 
                            Content="↻ Обновить" 
                            Height="35"
                            Margin="0,0,0,10"
                            Click="RefreshIllusionsButton_Click"
                            Background="{StaticResource LightGrayBrush}"
                            HorizontalAlignment="Left"
                            Width="120"/>

                    <DataGrid x:Name="IllusionsDataGrid" 
                              Grid.Row="1" 
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="300"/>
                            <DataGridTextColumn Header="Сила" Binding="{Binding Power}" Width="80"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding CreatedDate, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                            <DataGridTextColumn Header="Цель" Binding="{Binding Users.FullName}" Width="150"/>
                            <DataGridTextColumn Header="Заказ №" Binding="{Binding OrderId}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Статистика -->
            <TabItem Header="Статистика">
                <Grid Margin="15">
                    <StackPanel>
                        <TextBlock Text="Статистика иллюзий" 
                                   Style="{StaticResource HeaderStyle}"/>

                        <Border Background="{StaticResource LightGrayBrush}" 
                                Padding="20"
                                Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock x:Name="StatsTextBlock" 
                                           FontSize="14"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,10"/>

                                <Button Content="Обновить статистику" 
                                        Height="35"
                                        Width="180"
                                        Click="RefreshStatsButton_Click"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>