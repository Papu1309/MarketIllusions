<Page x:Class="MarketIllusions.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AdminPage"
      Background="{StaticResource WhiteBrush}">
    <Grid Margin="10">
        <TabControl>
            <TabItem Header="Пользователи">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" 
                                Orientation="Horizontal" 
                                Margin="0,0,0,10">
                        <Button Content="+ Добавить пользователя" 
                                Height="35"
                                Click="AddUserButton_Click"/>
                        <Button Content="↻ Обновить" 
                                Height="35"
                                Margin="10,0,0,0"
                                Click="RefreshUsersButton_Click"
                                Background="{StaticResource LightGrayBrush}"/>
                        <Button Content="Редактировать" 
                                Height="35"
                                Margin="10,0,0,0"
                                Click="EditUserButton_Click"
                                Visibility="Collapsed"
                                x:Name="EditUserButton"/>
                        <Button Content="Удалить" 
                                Height="35"
                                Margin="10,0,0,0"
                                Click="DeleteUserButton_Click"
                                Background="{StaticResource AccentBrush}"
                                Visibility="Collapsed"
                                x:Name="DeleteUserButton"/>
                    </StackPanel>

                    <DataGrid x:Name="UsersDataGrid" 
                              Grid.Row="1" 
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="UsersDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="120"/>
                            <DataGridTextColumn Header="Полное имя" Binding="{Binding FullName}" Width="180"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Внушаемость" Binding="{Binding SuggestibilityLevel}" Width="100"/>
                            <DataGridTextColumn Header="Дата регистрации" Binding="{Binding RegistrationDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding Roles.Name}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Товары">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" 
                                Orientation="Horizontal" 
                                Margin="0,0,0,10">
                        <Button Content="+ Добавить товар" 
                                Height="35"
                                Click="AddProductButton_Click"/>
                        <Button Content="↻ Обновить" 
                                Height="35"
                                Margin="10,0,0,0"
                                Click="RefreshProductsButton_Click"
                                Background="{StaticResource LightGrayBrush}"/>
                        <Button Content="Редактировать" 
                                Height="35"
                                Margin="10,0,0,0"
                                Click="EditProductButton_Click"
                                Visibility="Collapsed"
                                x:Name="EditProductButton"/>
                        <Button Content="Удалить" 
                                Height="35"
                                Margin="10,0,0,0"
                                Click="DeleteProductButton_Click"
                                Background="{StaticResource AccentBrush}"
                                Visibility="Collapsed"
                                x:Name="DeleteProductButton"/>
                    </StackPanel>

                    <DataGrid x:Name="ProductsDataGrid" 
                              Grid.Row="1" 
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="ProductsDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=C}" Width="100"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Categories.Name}" Width="120"/>
                            <DataGridTextColumn Header="Свойство" Binding="{Binding InvisibleProperty}" Width="150"/>
                            <DataGridTextColumn Header="Чистота" Binding="{Binding PurityPercent}" Width="80"/>
                            <DataGridTextColumn Header="Длительность" Binding="{Binding DurationMinutes}" Width="100"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="300"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Заказы">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" 
                                Orientation="Horizontal" 
                                Margin="0,0,0,10">
                        <Button Content="↻ Обновить" 
                                Height="35"
                                Click="RefreshOrdersButton_Click"
                                Background="{StaticResource LightGrayBrush}"/>
                        <Button Content="Изменить статус" 
                                Height="35"
                                Margin="10,0,0,0"
                                Click="ChangeOrderStatusButton_Click"
                                Visibility="Collapsed"
                                x:Name="ChangeOrderStatusButton"/>
                    </StackPanel>

                    <DataGrid x:Name="OrdersDataGrid" 
                              Grid.Row="1" 
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="OrdersDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Пользователь" Binding="{Binding Users.FullName}" Width="180"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat=C}" Width="100"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                            <DataGridTextColumn Header="Оплачен" Binding="{Binding IsPaid}" Width="80"/>
                            <DataGridTextColumn Header="Уровень иллюзии" Binding="{Binding IllusionLevel}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="История изменений">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" 
                Content="↻ Обновить" 
                Height="35"
                Margin="0,0,0,10"
                Click="RefreshHistoryButton_Click"
                Background="{StaticResource LightGrayBrush}"
                HorizontalAlignment="Left"
                Width="120"/>

                    <DataGrid x:Name="HistoryDataGrid" 
                  Grid.Row="1" 
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Товар" Binding="{Binding Products.Name}" Width="200"/>
                            <DataGridTextColumn Header="Дата изменения" Binding="{Binding ChangeDate, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                            <DataGridTextColumn Header="Пользователь" Binding="{Binding Users.FullName}" Width="180"/>
                            <DataGridTextColumn Header="Старая цена" Binding="{Binding OldPrice, StringFormat=C}" Width="120"/>
                            <DataGridTextColumn Header="Новая цена" Binding="{Binding NewPrice, StringFormat=C}" Width="120"/>
                            <DataGridTextColumn Header="Действие" Binding="{Binding Action}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>