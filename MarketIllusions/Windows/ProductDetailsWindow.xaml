<Window x:Class="MarketIllusions.Windows.ProductDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детальная информация" 
        Height="550" Width="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WhiteBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" 
                    Background="{StaticResource LightGrayBrush}"
                    Width="200" Height="150">
                <Image x:Name="ProductImage" 
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            </Border>

            <StackPanel Grid.Column="1" Margin="20,0,0,0">
                <TextBlock x:Name="NameTextBlock" 
                           FontSize="20" 
                           FontWeight="Light"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock x:Name="CategoryTextBlock" 
                           FontSize="12" 
                           Foreground="{StaticResource DarkTextBrush}" 
                           Margin="0,5,0,0"/>
                <TextBlock x:Name="PriceTextBlock" 
                           FontSize="18" 
                           FontWeight="Light" 
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,15,0,0"/>
                <TextBlock x:Name="DescriptionTextBlock" 
                           FontSize="13" 
                           TextWrapping="Wrap"
                           Foreground="{StaticResource DarkTextBrush}"
                           Margin="0,10,0,0"/>
                <TextBlock x:Name="InvisiblePropertyTextBlock" 
                           FontSize="11" 
                           Foreground="{StaticResource AccentBrush}" 
                           Margin="0,15,0,0"/>
                <TextBlock x:Name="DetailsTextBlock" 
                           FontSize="11"
                           Foreground="{StaticResource DarkTextBrush}"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="1" Margin="0,20,0,0">
            <TabItem Header="История изменений">
                <Grid>
                    <DataGrid x:Name="HistoryDataGrid" 
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              Margin="10"
                              ItemsSource="{Binding}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding ChangeDate, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                            <DataGridTextColumn Header="Старая цена" Binding="{Binding OldPrice, StringFormat=C}" Width="120"/>
                            <DataGridTextColumn Header="Новая цена" Binding="{Binding NewPrice, StringFormat=C}" Width="120"/>
                            <DataGridTextColumn Header="Действие" Binding="{Binding Action}" Width="150"/>
                            <DataGridTextColumn Header="Пользователь" Binding="{Binding Users.FullName}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Связанные иллюзии">
                <Grid>
                    <DataGrid x:Name="IllusionsDataGrid" 
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              Margin="10"
                              ItemsSource="{Binding}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="250"/>
                            <DataGridTextColumn Header="Сила" Binding="{Binding Power}" Width="80"/>
                            <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="В корзину" 
                    Width="120" 
                    Height="35"
                    Click="AddToCartButton_Click"/>
            <Button Content="Закрыть" 
                    Width="120" 
                    Height="35"
                    Margin="10,0,0,0"
                    Click="CloseButton_Click"
                    Background="{StaticResource LightGrayBrush}"/>
        </StackPanel>
    </Grid>
</Window>