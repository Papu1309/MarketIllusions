<Window x:Class="MarketIllusions.Windows.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование пользователя" 
        Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WhiteBrush}">
    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Редактирование пользователя" 
                           Style="{StaticResource HeaderStyle}"/>

                <Label Content="Логин"/>
                <TextBox x:Name="LoginTextBox" Height="35" IsReadOnly="True" 
                         Background="{StaticResource LightGrayBrush}"/>

                <Label Content="Полное имя"/>
                <TextBox x:Name="FullNameTextBox" Height="35"/>

                <Label Content="Email"/>
                <TextBox x:Name="EmailTextBox" Height="35"/>

                <Label Content="Телефон"/>
                <TextBox x:Name="PhoneTextBox" Height="35"/>

                <Label Content="Уровень внушаемости"/>
                <TextBox x:Name="SuggestibilityTextBox" Height="35"/>

                <Label Content="Роль"/>
                <ComboBox x:Name="RoleComboBox" Height="35"/>

                <Label Content="Новый пароль (оставьте пустым, если не менять)"/>
                <PasswordBox x:Name="PasswordBox" Height="35"/>

                <Grid Margin="0,25,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Button Content="Сохранить" 
                            Grid.Column="0" 
                            Margin="0,0,5,0"
                            Height="40"
                            Click="SaveButton_Click"/>
                    <Button Content="Отмена" 
                            Grid.Column="1" 
                            Margin="5,0,0,0"
                            Height="40"
                            Background="{StaticResource LightGrayBrush}"
                            Click="CancelButton_Click"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>