<Window x:Class="MarketIllusions.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        Height="400" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource WhiteBrush}">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Магазин" 
                       FontSize="28" 
                       FontWeight="Light"
                       Foreground="{StaticResource TextBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="воздуха, тишины и времени" 
                       FontSize="16" 
                       FontWeight="Light"
                       Foreground="{StaticResource DarkTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <TextBlock Text="Товары, которых нет, но они есть" 
                       FontSize="11" 
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"
                       TextAlignment="Center"/>

            <Label Content="Логин"/>
            <TextBox x:Name="LoginTextBox" Height="35"/>

            <Label Content="Пароль"/>
            <PasswordBox x:Name="PasswordBox" Height="35" Margin="0,2,0,20"/>

            <Button Content="Войти" 
                    Height="40"
                    FontSize="14"
                    Click="LoginButton_Click"/>

            <Button Content="Регистрация" 
                    Height="40"
                    FontSize="14"
                    Background="{StaticResource LightGrayBrush}"
                    Click="RegisterButton_Click"/>

            <TextBlock x:Name="ErrorTextBlock" 
                       Foreground="#FF6666" 
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"
                       FontSize="12"/>

            <!-- Подсказка -->
            <TextBlock Text="admin / admin123" 
                       FontSize="10"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"/>
        </StackPanel>
    </Grid>
</Window>