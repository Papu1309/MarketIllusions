<Window x:Class="MarketIllusions.Windows.IllusionCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание иллюзии" 
        Height="450" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WhiteBrush}">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Создание иллюзии" 
                       Style="{StaticResource HeaderStyle}"/>

            <TextBlock x:Name="ProductInfoTextBlock" 
                       FontWeight="Bold" 
                       FontSize="13"
                       Foreground="{StaticResource TextBrush}"
                       Margin="0,0,0,15"/>

            <Label Content="Название иллюзии"/>
            <TextBox x:Name="NameTextBox" Height="35"/>

            <Label Content="Описание"/>
            <TextBox x:Name="DescriptionTextBox" 
                     Height="80" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True"/>

            <Label Content="Сила иллюзии (0-100)"/>
            <TextBox x:Name="PowerTextBox" 
                     Text="75" 
                     Height="35"/>

            <Grid Margin="0,25,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button Content="Создать" 
                        Grid.Column="0" 
                        Margin="0,0,5,0"
                        Height="40"
                        Click="CreateButton_Click"/>
                <Button Content="Отмена" 
                        Grid.Column="1" 
                        Margin="5,0,0,0"
                        Height="40"
                        Background="{StaticResource LightGrayBrush}"
                        Click="CancelButton_Click"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>