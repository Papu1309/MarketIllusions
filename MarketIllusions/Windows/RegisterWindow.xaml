<Window x:Class="MarketIllusions.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" 
        Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource WhiteBrush}">
    <Grid Margin="25">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Регистрация" 
                           Style="{StaticResource HeaderStyle}"
                           HorizontalAlignment="Center"/>

                <Label Content="Логин *"/>
                <TextBox x:Name="LoginTextBox" Height="35"/>

                <Label Content="Пароль *"/>
                <PasswordBox x:Name="PasswordBox" Height="35"/>

                <Label Content="Подтверждение пароля *"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Height="35"/>

                <Label Content="Полное имя *"/>
                <TextBox x:Name="FullNameTextBox" Height="35"/>

                <Label Content="Email"/>
                <TextBox x:Name="EmailTextBox" Height="35"/>

                <Label Content="Телефон"/>
                <TextBox x:Name="PhoneTextBox" Height="35"/>

                <Label Content="Уровень внушаемости (0-100)"/>
                <TextBox x:Name="SuggestibilityTextBox" 
                         Text="50" 
                         Height="35"/>

                <Button Content="Зарегистрироваться" 
                        Height="40"
                        Margin="0,15,0,0"
                        Click="RegisterButton_Click"/>

                <Button Content="Отмена" 
                        Height="40"
                        Margin="0,5,0,0"
                        Background="{StaticResource LightGrayBrush}"
                        Click="CancelButton_Click"/>

                <TextBlock x:Name="ErrorTextBlock" 
                           Foreground="#FF6666" 
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>