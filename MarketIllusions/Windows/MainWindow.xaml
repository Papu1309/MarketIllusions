<Window x:Class="MarketIllusions.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин воздуха, тишины и времени" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WhiteBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" 
                Background="{StaticResource LightGrayBrush}" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="0,0,0,1">
            <Grid Margin="15,0">
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Left" 
                            VerticalAlignment="Center">
                    <TextBlock Text="Добро пожаловать," 
                               FontSize="13"
                               Foreground="{StaticResource DarkTextBrush}"/>
                    <TextBlock x:Name="UserNameTextBlock" 
                               FontSize="13" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="5,0,0,0"/>
                    <TextBlock Text="|" 
                               FontSize="13" 
                               Foreground="{StaticResource AccentBrush}"
                               Margin="15,0"/>
                    <TextBlock Text="Роль:" 
                               FontSize="13" 
                               Foreground="{StaticResource DarkTextBrush}"
                               Margin="5,0,0,0"/>
                    <TextBlock x:Name="UserRoleTextBlock" 
                               FontSize="13" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="5,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center">
                    <Button Content="Каталог" 
                            Click="CatalogButton_Click" 
                            Width="100"
                            Background="Transparent"
                            BorderThickness="0"/>
                    <Button x:Name="ProfileButton" 
                            Content="Профиль" 
                            Click="ProfileButton_Click" 
                            Width="100"
                            Background="Transparent"
                            BorderThickness="0"/>
                    <Button x:Name="AdminButton" 
                            Content="Администрирование" 
                            Click="AdminButton_Click" 
                            Width="140" 
                            Visibility="Collapsed"
                            Background="Transparent"
                            BorderThickness="0"/>
                    <Button x:Name="IllusionistButton" 
                            Content="Иллюзии" 
                            Click="IllusionistButton_Click" 
                            Width="120" 
                            Visibility="Collapsed"
                            Background="Transparent"
                            BorderThickness="0"/>
                    <Button x:Name="CartButton" 
                            Content="Корзина" 
                            Click="CartButton_Click" 
                            Width="100"
                            Background="Transparent"
                            BorderThickness="0"/>
                    <Button Content="Выход" 
                            Click="LogoutButton_Click" 
                            Width="100"
                            Background="Transparent"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Frame x:Name="MainFrame" 
               Grid.Row="1" 
               NavigationUIVisibility="Hidden"
               Background="{StaticResource WhiteBrush}"/>

        <Border Grid.Row="2" 
                Background="{StaticResource LightGrayBrush}"
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="0,1,0,0">
            <TextBlock Text="МагазинЧИК Ильмира (Великий ОНГОИНГ) воздуха, тишины и времени." 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       FontSize="11"
                       Foreground="{StaticResource DarkTextBrush}"/>
        </Border>
    </Grid>
</Window>